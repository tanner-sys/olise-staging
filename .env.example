VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Brain service (proxies Claude — required; browser cannot call Anthropic directly)
VITE_BRAIN_URL=http://localhost:8080

